# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://xoggai:xoggai@localhost:5432/xoggai

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# x402 / AgentCash wallet
X402_WALLET_PRIVATE_KEY=0x...
X402_WALLET_ADDRESS=0x...
X402_NETWORK=base-mainnet

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://xoggai.xyz

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Cache TTL (seconds)
STATS_CACHE_TTL=30
SEARCH_CACHE_TTL=60

# Execution safety
ALLOW_LIVE_EXECUTION=false
