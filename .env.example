# Server
PORT=3000
NODE_ENV=development
SERVICE_VERSION=development
DEPLOYMENT_ENVIRONMENT=development

# PostgreSQL
DATABASE_URL=postgresql://xoggai:xoggai@localhost:5432/xoggai

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=
ANTHROPIC_ROUTER_MODEL=claude-sonnet-4-5
ANTHROPIC_RATING_MODEL=claude-haiku-4-5-20251001

# x402 / AgentCash wallet
X402_WALLET_PRIVATE_KEY=0x...
X402_WALLET_ADDRESS=0x...
X402_NETWORK=base-sepolia

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://xoggai.xyz

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Cache TTL (seconds)
STATS_CACHE_TTL=30
SEARCH_CACHE_TTL=60

# Execution safety
ALLOW_LIVE_EXECUTION=false
EXECUTION_SIMULATION_ENABLED=false
X402_PREPARE_ENABLED=true
X402_SIGNING_ENABLED=true
X402_VERIFY_ENABLED=true
X402_SETTLEMENT_ENABLED=false
X402_UPSTREAM_EXECUTION_ENABLED=true
X402_FACILITATOR_URL=https://x402.org/facilitator
BETA_EXECUTION_KEY=
BETA_ACCESS_KEYS=
BETA_DAILY_REQUEST_LIMIT=25
BETA_DAILY_BUDGET_USDC=0.05
PUBLIC_BETA_ADMIN_KEY=
PUBLIC_BETA_SESSION_TTL_SECONDS=86400
PUBLIC_BETA_REQUEST_TTL_SECONDS=900
PUBLIC_BETA_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_BETA_RATE_LIMIT_MAX=10
PUBLIC_BETA_ALERT_REQUEST_SPIKE=50
PUBLIC_BETA_ALERT_FAILURE_THRESHOLD=5
PUBLIC_BETA_ENABLED=true
OPERATIONS_KILL_SWITCH=false
READINESS_TIMEOUT_MS=2500
MAX_EXECUTION_BUDGET_USDC=0.005
EXECUTION_ENDPOINT_ALLOWLIST=
