{
  "openapi": "3.1.0",
  "info": {
    "title": "XoggAI API",
    "version": "1.0.0",
    "description": "Intent routing API for x402 endpoints."
  },
  "servers": [
    { "url": "http://localhost:3000", "description": "Local development" },
    { "url": "https://xoggai-backend.onrender.com", "description": "Production" }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Server status"
          }
        }
      }
    },
    "/ready": {
      "get": {
        "summary": "Dependency readiness check",
        "responses": {
          "200": {
            "description": "PostgreSQL and Redis are available"
          },
          "503": {
            "description": "One or more required dependencies are unavailable"
          }
        }
      }
    },
    "/intent": {
      "get": {
        "summary": "Route a natural-language intent",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "minLength": 3, "maxLength": 500 }
          },
          {
            "name": "budget",
            "in": "query",
            "required": false,
            "schema": { "type": "number", "default": 0.05, "maximum": 10 }
          },
          {
            "name": "dry",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": true }
          }
        ],
        "responses": {
          "200": { "description": "Intent routed successfully" },
          "403": { "description": "Live execution must use the controlled execution endpoint" },
          "402": { "description": "Budget exceeded" },
          "404": { "description": "No endpoint found" }
        }
      }
    },
    "/search": {
      "get": {
        "summary": "Search registered x402 endpoints",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 10, "maximum": 50 }
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "min_rating",
            "in": "query",
            "required": false,
            "schema": { "type": "number", "default": 0, "minimum": 0, "maximum": 5 }
          },
          {
            "name": "dry",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": true }
          }
        ],
        "responses": {
          "200": { "description": "Ranked endpoint results" }
        }
      }
    },
    "/execute": {
      "post": {
        "summary": "Evaluate closed-beta execution policy",
        "description": "Server-side policy simulation only. Requires EXECUTION_SIMULATION_ENABLED=true, independently of live execution. Never expose the beta key in browser code. This endpoint never sends payment or calls the selected upstream API.",
        "parameters": [
          {
            "name": "x-beta-key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["intent", "endpointId", "budget"],
                "properties": {
                  "intent": { "type": "string", "minLength": 3, "maxLength": 500 },
                  "endpointId": { "type": "string", "format": "uuid" },
                  "budget": { "type": "number", "exclusiveMinimum": 0, "maximum": 10 },
                  "mode": { "type": "string", "const": "simulation", "default": "simulation" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Policy passed; no payment was sent" },
          "400": { "description": "Invalid request" },
          "401": { "description": "Invalid beta access" },
          "403": { "description": "Execution policy blocked the request" },
          "404": { "description": "Endpoint not found" },
          "503": { "description": "Simulation is disabled or beta access is not configured" }
        }
      }
    },
    "/execute/upstream": {
      "post": {
        "summary": "Execute one audited x402 upstream resource",
        "description": "Closed-beta server-side path only. Requires X402_UPSTREAM_EXECUTION_ENABLED=true, a server-side x-beta-key, a VERIFIED ticket, and explicit EXECUTE_X402_BASE_SEPOLIA confirmation. Never call this from browser-delivered code.",
        "parameters": [
          {
            "name": "x-beta-key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["ticketId", "executionConfirmation", "paymentPayload"],
                "properties": {
                  "ticketId": { "type": "string", "format": "uuid" },
                  "executedBy": { "type": "string" },
                  "executionConfirmation": { "type": "string", "const": "EXECUTE_X402_BASE_SEPOLIA" },
                  "paymentPayload": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Audited upstream execution completed or returned a terminal failure" },
          "400": { "description": "Invalid request" },
          "401": { "description": "Invalid beta access" },
          "409": { "description": "Ticket or execution guardrail rejected the request" },
          "503": { "description": "Upstream execution is disabled or beta access is not configured" }
        }
      }
    },
    "/api/beta/executions": {
      "get": {
        "summary": "Inspect the requesting beta agent's execution ledger",
        "description": "Server-side beta integration only. Returns limits, daily usage, and tickets owned by the supplied beta key.",
        "parameters": [
          {
            "name": "x-beta-key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 25 }
          }
        ],
        "responses": {
          "200": { "description": "Beta identity, limits, usage, and scoped execution ledger" },
          "400": { "description": "Invalid request" },
          "401": { "description": "Invalid beta access" }
        }
      }
    },
    "/api/beta/auth/login": {
      "post": {
        "summary": "Exchange an invited beta API key for a short-lived session",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["apiKey"],
                "properties": { "apiKey": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Authenticated user and one-time session token" },
          "401": { "description": "Invalid or revoked beta credentials" }
        }
      }
    },
    "/api/beta/dashboard/me": {
      "get": {
        "summary": "Get the authenticated beta account and daily usage",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "example": "Bearer xg_session_..." }
          }
        ],
        "responses": {
          "200": { "description": "Scoped beta account, limits, and usage" },
          "401": { "description": "Invalid or expired session" }
        }
      }
    },
    "/api/beta/dashboard/requests": {
      "get": {
        "summary": "List the authenticated user's execution requests",
        "responses": {
          "200": { "description": "User-scoped approval requests" },
          "401": { "description": "Invalid or expired session" }
        }
      },
      "post": {
        "summary": "Dry-run an intent and submit it for operator approval",
        "description": "This endpoint cannot send payment.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["intent", "budgetUsdc"],
                "properties": {
                  "intent": { "type": "string", "minLength": 3, "maxLength": 500 },
                  "budgetUsdc": { "type": "number", "exclusiveMinimum": 0, "maximum": 0.005 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Dry-run preview and pending approval request" },
          "401": { "description": "Invalid or expired session" },
          "403": { "description": "Per-request budget exceeded" },
          "429": { "description": "Daily quota exceeded" }
        }
      }
    },
    "/api/admin/beta/requests/{id}/execute-testnet": {
      "post": {
        "summary": "Execute an approved public beta request on Base Sepolia",
        "description": "Protected admin endpoint. Runs the approved request through prepare, approve, consume, sign, verify, and audited upstream x402 execution on Base Sepolia. Mainnet remains disabled.",
        "parameters": [
          {
            "name": "x-admin-key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["executedBy"],
                "properties": {
                  "executedBy": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Request reached a terminal testnet execution state" },
          "401": { "description": "Invalid admin access" },
          "409": { "description": "Request is not approved or is already executing" },
          "503": { "description": "Testnet execution is not configured" }
        }
      }
    },
    "/api/stats": {
      "get": {
        "summary": "Platform statistics",
        "responses": {
          "200": { "description": "Aggregate stats" }
        }
      }
    },
    "/api/info": {
      "get": {
        "summary": "Service information",
        "responses": {
          "200": { "description": "Public service metadata, mode, docs, and endpoint links" }
        }
      }
    },
    "/api/feed": {
      "get": {
        "summary": "Live routing event feed",
        "responses": {
          "200": { "description": "Server-sent events stream" }
        }
      }
    },
    "/api/endpoints": {
      "get": {
        "summary": "Explore registered endpoints",
        "responses": {
          "200": { "description": "Endpoint list" }
        }
      }
    }
  }
}
